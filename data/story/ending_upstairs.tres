script = ExtResource("1")
id = "ending_upstairs"
text = "The stairs groan under your weight. At the top, a single candle burns in an empty room, though no one lit it. You decide it is best not to ask why.\n\n— You made it out with your curiosity intact. —"
set_flags_on_enter = {}
