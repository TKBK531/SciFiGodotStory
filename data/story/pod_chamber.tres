[gd_resource type="Resource" script_class="StoryNode" format=3 uid="uid://cc0a8byekgdjk"]

[ext_resource type="Script" uid="uid://keyu0yarniql" path="res://scripts/resources/story_node.gd" id="1"]
[ext_resource type="Script" uid="uid://dwrp88fmyeigl" path="res://scripts/resources/story_choice.gd" id="2"]

[sub_resource type="Resource" id="StoryChoice_open_trust"]
script = ExtResource("2")
text = "Open the pod and let it see you."
target_node_id = "ending_bond"
required_flags = {
"learned_truth": true
}

[sub_resource type="Resource" id="StoryChoice_open_force"]
script = ExtResource("2")
text = "Force the pod open."
target_node_id = "ending_consumed"
required_flags = {
"learned_truth": false
}

[sub_resource type="Resource" id="StoryChoice_escape"]
script = ExtResource("2")
text = "Kill the life support and go."
target_node_id = "ending_escape"

[resource]
script = ExtResource("1")
id = "pod_chamber"
text = "Deeper in the station, the corridor opens into what used to be the medbay. A containment pod stands upright at its center, its casing grown over with something that looks like frost and veins at once. Inside, a shape shifts - not quite human anymore, but the outline is unmistakably Voss.

The heartbeat on your scanner is perfectly in time with your own now."
choices = Array[ExtResource("2")]([SubResource("StoryChoice_open_trust"), SubResource("StoryChoice_open_force"), SubResource("StoryChoice_escape")])
