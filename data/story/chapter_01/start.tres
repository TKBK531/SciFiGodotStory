[resource]
script = ExtResource("1")
id = "start"
chapter_id = "chapter_01"
label = "Arrival"
text = "Kharon-9's distress beacon has been pulsing for six years. You only picked it up because your ship's old military-band receiver still listens on frequencies nobody uses anymore.\n\nThe station is dark except for one corridor light, guttering behind a frost-sealed airlock. Your suit's bio-scanner locks onto something inside - a heartbeat, slow and steady, where the crew manifest says there should be nothing left alive."
set_flags_on_enter = {}
is_chapter_end = false
choices = [SubResource("StoryChoice_force"), SubResource("StoryChoice_hack")]
