[gd_resource type="Resource" script_class="StoryNode" format=3 uid="uid://b0t1gqff0axqp"]

[ext_resource type="Script" uid="uid://keyu0yarniql" path="res://scripts/resources/story_node.gd" id="1"]
[ext_resource type="Script" uid="uid://dwrp88fmyeigl" path="res://scripts/resources/story_choice.gd" id="2"]

[sub_resource type="Resource" id="StoryChoice_force"]
script = ExtResource("2")
text = "Force the airlock open."
target_node_id = "pod_chamber"
set_flags = {
"forced": true,
"learned_truth": false
}
attribute_changes = {
"courage": 1
}
faction_changes = {
"government": -5
}
impact = 2

[sub_resource type="Resource" id="StoryChoice_hack"]
script = ExtResource("2")
text = "Slice into the console instead."
target_node_id = "console_intel"
set_flags = {
"hacked": true
}
attribute_changes = {
"empathy": 1
}
faction_changes = {
"government": 5
}
impact = 2

[resource]
script = ExtResource("1")
id = "start"
chapter_id = "chapter_01"
label = "Arrival"
text = "[codex:kharon9]Kharon-9[/codex]'s distress beacon has been pulsing for six years. You only picked it up because your ship's old military-band receiver still listens on frequencies nobody uses anymore.

The station is dark except for one corridor light, guttering behind a frost-sealed airlock. Your suit's bio-scanner locks onto something inside - a heartbeat, slow and steady, where the crew manifest says there should be nothing left alive."
choices = Array[ExtResource("2")]([SubResource("StoryChoice_force"), SubResource("StoryChoice_hack")])
