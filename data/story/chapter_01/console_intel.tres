[resource]
script = ExtResource("1")
id = "console_intel"
chapter_id = "chapter_01"
label = "The Logs"
text = "The console's shell is pitted with frost, but its core still runs warm. You bridge your slate to what's left of the station network and pull whatever the drives haven't eaten.\n\nResearch logs. A retrieval mission gone wrong on one of Saturn's ice moons. A specimen the crew called \"[codex:the_bloom]the Bloom[/codex]\" - not a weapon, not a parasite, something closer to a language. The last entry is Commander [codex:voss]Elias Voss[/codex]'s voice, calm: \"It isn't taking anything from us. It's asking.\""
set_flags_on_enter = {}
is_chapter_end = false
choices = [SubResource("StoryChoice_follow")]
